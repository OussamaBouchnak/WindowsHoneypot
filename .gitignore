# Sensitive data
*.csv
*.json
data/
!data/.gitkeep
*.key
*.pem
.env
config.local.yaml

# API keys (never commit!)
*api_key*
*secret*
*password*

# Azure
*.publishsettings
*.azureProfile

# IDE
.vscode/
.idea/
*.swp
*.swo
*.sublime-*

# OS
.DS_Store
Thumbs.db
desktop.ini

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Wordlists (can be large)
wordlists/*.txt
!wordlists/usernames.txt
!wordlists/passwords.txt

# Temporary files
tmp/
temp/
*.tmp

